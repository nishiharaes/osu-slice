<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="osu!slice" Height="600" Width="400"
        Background="#221f2e"
        FontFamily="./Assets/Fonts/#Torus Regular">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="osu!slice" FontSize="70" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,20,0,40">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Input Fields -->
        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Width="350">

            <!-- Start Time -->
            <StackPanel Orientation="Horizontal" Margin="5,0,0,20">
                <TextBlock Text="Start Time:" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="130"/>
                <Border CornerRadius="8" Background="#2D2D30" BorderBrush="#555" BorderThickness="1" SnapsToDevicePixels="True">
                    <TextBox Name="StartTimeTextBox" Height="40" FontSize="18" Padding="10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                </Border>
            </StackPanel>

            <!-- End Time -->
            <StackPanel Orientation="Horizontal" Margin="5,0,0,20">
                <TextBlock Text="End Time:" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="130"/>
                <Border CornerRadius="8" Background="#2D2D30" BorderBrush="#555" BorderThickness="1" SnapsToDevicePixels="True">
                    <TextBox Name="EndTimeTextBox" Height="40" FontSize="18" Padding="10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                </Border>
            </StackPanel>

            <!-- Difficulty Name -->
            <StackPanel Orientation="Horizontal" Margin="5,0,0,20">
                <TextBlock Text="Difficulty Name:" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="150"/>
                <Border CornerRadius="8" Background="#2D2D30" BorderBrush="#555" BorderThickness="1" SnapsToDevicePixels="True">
                    <TextBox Name="DifficultyTextBox" Height="40" FontSize="18" Padding="10" Background="Transparent" Foreground="White" BorderThickness="0"/>
                </Border>
            </StackPanel>

        </StackPanel>

        <!-- Create Button -->
        <Button Grid.Row="2" Content="Create Difficulty" Width="220" Height="50" FontSize="20"
                HorizontalAlignment="Center" Margin="0,40,0,30" Cursor="Hand" Foreground="White" BorderThickness="0">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6EC7" Offset="0"/>
                    <GradientStop Color="#FF4081" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
            <Button.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3"/>
            </Button.Effect>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="12" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>